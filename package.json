{
	"name": "obsidian-tray",
	"version": "0.3.5",
	"description": "Run Obsidian from the system tray for customisable window management & global quick notes",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"build": "node esbuild.config.mjs production",
		"dev": "node esbuild.config.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"typecheck": "tsc --noEmit"
	},
	"packageManager": "pnpm@10.15.0",
	"keywords": [
		"obsidian",
		"plugin",
		"tray",
		"system-tray",
		"window-management",
		"quick-notes"
	],
	"authors": [
		"dragonwocky <thedragonring.bod@gmail.com> (https://dragonwocky.me/)",
		"Oliver Dudgeon"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.33.0",
		"@types/node": "^20.19.11",
		"builtin-modules": "^3.3.0",
		"esbuild": "0.21.5",
		"eslint": "^9.33.0",
		"obsidian": "latest",
		"typescript": "^5.9.2"
	}
}
