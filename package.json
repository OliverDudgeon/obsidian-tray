{
	"name": "obsidian-tray",
	"version": "1.0.1",
	"description": "Run Obsidian from the system tray for customisable window management & global quick notes",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"packageManager": "pnpm@10.15.0",
	"keywords": [
		"obsidian",
		"plugin",
		"tray",
		"system-tray",
		"window-management",
		"quick-notes"
	],
	"authors": [
		"dragonwocky <thedragonring.bod@gmail.com> (https://dragonwocky.me/)",
		"Oliver Dudgeon"
	],
	"license": "MIT",
	"dependencies": {
		"obsidian": "latest",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.30.1",
		"@types/node": "^22.10.0",
		"esbuild": "^0.25.5",
		"eslint": "^9.30.1",
		"eslint-plugin-obsidianmd": "^0.1.9",
		"globals": "^15.14.0",
		"jiti": "^2.6.1",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.35.1"
	}
}
